NODE_ENV=development

PORT=4000

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=rag_db
DB_USER=postgres
DB_PASS=postgres

# JWT secrets — use strong random values in production
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=900        # 15 minutes (seconds)
JWT_REFRESH_EXPIRES_IN=604800    # 7 days (seconds)

COOKIE_DOMAIN=

# Object Storage (S3-compatible: Cloudflare R2, AWS S3, Supabase)
# Use Cloudflare R2 for free tier: https://developers.cloudflare.com/r2/
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET=rag-uploads
STORAGE_PUBLIC_URL=
STORAGE_FORCE_PATH_STYLE=true
STORAGE_SIGNED_URL_EXPIRES=3600
STORAGE_MAX_FILE_SIZE=10485760        # 10 MB (bytes)
STORAGE_ALLOWED_MIME_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,text/csv
