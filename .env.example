NODE_ENV=development

PORT=4000

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=rag_db
DB_USER=postgres
DB_PASS=postgres

# CORS
ORIGINS='["http://localhost:5173"]'

# JWT secrets — use strong random values in production
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=1800        # 30 minutes (seconds)
JWT_REFRESH_EXPIRES_IN=604800    # 7 days (seconds)

COOKIE_DOMAIN=

# ──────────────────────────────────────────────
# Object Storage (S3-compatible)
# Cloudflare R2 (free tier), AWS S3, Supabase
# ──────────────────────────────────────────────
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET=rag-uploads
STORAGE_PUBLIC_URL=
STORAGE_FORCE_PATH_STYLE=true
STORAGE_SIGNED_URL_EXPIRES=3600
STORAGE_MAX_FILE_SIZE=52428800          # 50 MB (bytes)
STORAGE_ALLOWED_MIME_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,text/csv

# ──────────────────────────────────────────────
# Upload Configuration
# ──────────────────────────────────────────────
UPLOAD_MAX_FILE_SIZE_MB=50
UPLOAD_ALLOWED_TYPES=pdf,docx,xlsx,xls
UPLOAD_TEMP_DIR=/tmp/documents

# ──────────────────────────────────────────────
# Job Queue (Redis-backed Bull)
# ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
DOCUMENT_QUEUE_NAME=document-processing
JOB_TIMEOUT_SECONDS=300
JOB_MAX_ATTEMPTS=3
JOB_BACKOFF_DELAY_MS=2000

# ──────────────────────────────────────────────
# Chunking Configuration
# ──────────────────────────────────────────────
CHUNK_TOKEN_LIMIT=1000
CHUNK_OVERLAP_PERCENT=15
CHUNK_MIN_TOKENS=50
CHUNK_MAX_TOKENS=2000

# ──────────────────────────────────────────────
# Embedding Configuration (OpenAI)
# ──────────────────────────────────────────────
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=sk-...
EMBEDDING_BATCH_SIZE=50
EMBEDDING_RATE_LIMIT_MS=100
EMBEDDING_MAX_RETRIES=3

# ──────────────────────────────────────────────
# Retrieval / Hybrid Search
# ──────────────────────────────────────────────
HYBRID_SEARCH_ENABLED=true            # Enable hybrid (vector + BM25) retrieval
VECTOR_TOP_K=20                       # Candidates from vector search
BM25_TOP_K=20                         # Candidates from BM25 keyword search
RERANK_TOP_K=5                        # Final candidates after reranking

# ──────────────────────────────────────────────
# Relevance Threshold (Hallucination Guard)
# ──────────────────────────────────────────────
RELEVANCE_THRESHOLD=0.0              # Min similarity to invoke LLM (0.0 = disabled)

# ──────────────────────────────────────────────
# Reranker
# ──────────────────────────────────────────────
RERANKER_PROVIDER=none                # Options: none (score fusion), cohere
RERANKER_MODEL=rerank-english-v3.0   # Cohere model name
# COHERE_API_KEY=                     # Required if RERANKER_PROVIDER=cohere

# ──────────────────────────────────────────────
# Query Rewriting
# ──────────────────────────────────────────────
QUERY_REWRITING_ENABLED=false         # Rewrite ambiguous queries before retrieval
# QUERY_REWRITER_MODEL=gpt-4o-mini    # Model for rewriting (defaults to LLM_MODEL)

# ──────────────────────────────────────────────
# Evaluation
# ──────────────────────────────────────────────
EVALUATION_ENABLED=false              # Enable evaluation metrics tracking
