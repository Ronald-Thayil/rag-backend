NODE_ENV=development

PORT=4000

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=rag_db
DB_USER=postgres
DB_PASS=postgres

# JWT secrets — use strong random values in production
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=900        # 15 minutes (seconds)
JWT_REFRESH_EXPIRES_IN=604800    # 7 days (seconds)

COOKIE_DOMAIN=

# ──────────────────────────────────────────────
# Object Storage (S3-compatible)
# Cloudflare R2 (free tier), AWS S3, Supabase
# ──────────────────────────────────────────────
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET=rag-uploads
STORAGE_PUBLIC_URL=
STORAGE_FORCE_PATH_STYLE=true
STORAGE_SIGNED_URL_EXPIRES=3600
STORAGE_MAX_FILE_SIZE=52428800          # 50 MB (bytes)
STORAGE_ALLOWED_MIME_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,text/csv

# ──────────────────────────────────────────────
# Upload Configuration
# ──────────────────────────────────────────────
UPLOAD_MAX_FILE_SIZE_MB=50
UPLOAD_ALLOWED_TYPES=pdf,docx,xlsx,xls
UPLOAD_TEMP_DIR=/tmp/documents

# ──────────────────────────────────────────────
# Job Queue (Redis-backed Bull)
# ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
DOCUMENT_QUEUE_NAME=document-processing
JOB_TIMEOUT_SECONDS=300
JOB_MAX_ATTEMPTS=3
JOB_BACKOFF_DELAY_MS=2000

# ──────────────────────────────────────────────
# Chunking Configuration
# ──────────────────────────────────────────────
CHUNK_TOKEN_LIMIT=1000
CHUNK_OVERLAP_PERCENT=15
CHUNK_MIN_TOKENS=50
CHUNK_MAX_TOKENS=2000

# ──────────────────────────────────────────────
# Embedding Configuration (OpenAI)
# ──────────────────────────────────────────────
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=sk-...
EMBEDDING_BATCH_SIZE=50
EMBEDDING_RATE_LIMIT_MS=100
EMBEDDING_MAX_RETRIES=3
