        {
          "name": "Get Document Chunks",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/documents/{{documentId}}/chunks",
              "host": ["{{baseUrl}}"],
              "path": ["documents", "{{documentId}}", "chunks"]
            },
            "description": "Get all text chunks for a processed document."
          },
          "response": []
        }
      ],
      "description": "RAG document management endpoints"
    },
