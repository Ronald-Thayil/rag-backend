    {
      "name": "Auth",
      "item": [
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken', json.data.access_token);",
                  "    pm.collectionVariables.set('refreshToken', json.data.refresh_token);",
                  "    pm.collectionVariables.set('companyId', json.data.company_id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"your-password\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login/user",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login", "user"]
            },
            "description": "Login as a regular user (member or company_admin).\n\n**Rate limit:** 10 requests per 15 minutes per IP.\n\n**Response stores** `accessToken` and `refreshToken` as collection variables."
          },
          "response": []
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken', json.data.access_token);",
                  "    pm.collectionVariables.set('refreshToken', json.data.refresh_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"your-password\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login/admin",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login", "admin"]
            },
            "description": "Login as a platform admin.\n\n**Rate limit:** 10 requests per 15 minutes per IP.\n\n**Response stores** `accessToken` and `refreshToken` as collection variables."
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken', json.data.access_token);",
                  "    pm.collectionVariables.set('refreshToken', json.data.refresh_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh"]
            },
            "description": "Refresh an expired access token using a valid refresh token.\n\n**Response stores** the new `accessToken` and `refreshToken`."
          },
          "response": []
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.collectionVariables.set('accessToken', '');",
                  "pm.collectionVariables.set('refreshToken', '');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            },
            "description": "Logout and invalidate the refresh token. Clears stored tokens on success."
          },
          "response": []
        }
      ],
      "description": "Authentication endpoints"
    },
    {
      "name": "Storage",
      "item": [
        {
          "name": "Upload File",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    var json = pm.response.json();",
                  "    if (json.data && json.data.key) {",
                  "        pm.collectionVariables.set('storageKey', json.data.key);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "X-Requested-With",
                "value": "XMLHttpRequest"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "File to upload (pdf, docx, xlsx, csv)"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/storage/upload",
              "host": ["{{baseUrl}}"],
              "path": ["storage", "upload"]
            },
            "description": "Upload a file to object storage. Stores returned `key` as `storageKey` variable.\n\n**Allowed types:** pdf, docx, xlsx, csv\n**Max size:** 50 MB"
          },
          "response": []
        },
        {
          "name": "Download File",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/storage/download/{{storageKey}}",
              "host": ["{{baseUrl}}"],
              "path": ["storage", "download", "{{storageKey}}"]
            },
            "description": "Download a file by its storage key."
          },
          "response": []
        },
        {
          "name": "Get Signed URL",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/storage/signed-url/{{storageKey}}",
              "host": ["{{baseUrl}}"],
              "path": ["storage", "signed-url", "{{storageKey}}"]
            },
            "description": "Get a time-limited signed URL for direct access to a stored file.\n\n**Default expiry:** 3600 seconds (1 hour)"
          },
          "response": []
        },
        {
          "name": "Delete File",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "X-Requested-With",
                "value": "XMLHttpRequest"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/storage/{{storageKey}}",
              "host": ["{{baseUrl}}"],
              "path": ["storage", "{{storageKey}}"]
            },
            "description": "Delete a file from object storage by its key."
          },
          "response": []
        }
      ],
      "description": "Object storage endpoints (S3-compatible)"
    },
