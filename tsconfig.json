{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "outDir": "dist",
    "baseUrl": "./",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@routes": [
        "src/routes"
      ],
      "@controllers": [
        "src/controllers"
      ],
      "@services": [
        "src/services"
      ],
      "@middlewares": [
        "src/middlewares"
      ],
      "@models": [
        "src/models"
      ],
      "@config": [
        "src/config"
      ],
      "@utils": [
        "src/utils"
      ],
      "@types": [
        "src/types"
      ],
      "@interfaces": [
        "src/interfaces"
      ],
      "@shared": [
        "src/shared"
      ]
    }
  }
}